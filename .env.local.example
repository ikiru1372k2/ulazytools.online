# Local development infrastructure
DATABASE_URL="postgresql://ulazytools:ulazytools@localhost:5432/ulazytools"
DIRECT_URL="postgresql://ulazytools:ulazytools@localhost:5432/ulazytools"
# In pooled/serverless deployments, point DIRECT_URL at the direct (non-pooled) connection.
REDIS_URL="redis://localhost:6379"

# Auth.js / Google OAuth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_GOOGLE_ID="replace-with-google-oauth-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-oauth-client-secret"
# Google OAuth callback URL for local development:
# http://localhost:3000/api/auth/callback/google
# Local S3-compatible object storage (MinIO)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="ulazytools"
S3_SECRET_ACCESS_KEY="ulazytools-minio-secret"
S3_BUCKET="ulazy-pdf-dev"
S3_FORCE_PATH_STYLE="true"
