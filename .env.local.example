# Local development infrastructure
# Canonical server env validation lives in src/lib/env.ts.
DATABASE_URL="postgresql://ulazytools:ulazytools@localhost:5432/ulazytools"
DIRECT_URL="postgresql://ulazytools:ulazytools@localhost:5432/ulazytools"
# In pooled/serverless deployments, point DIRECT_URL at the direct (non-pooled) connection.
REDIS_URL="redis://localhost:6379"

# Auth.js / Google OAuth
AUTH_SECRET="replace-with-a-long-random-secret"
# Optional alias if a deployment still uses NEXTAUTH naming.
# NEXTAUTH_SECRET="replace-with-a-long-random-secret"
AUTH_GOOGLE_ID="replace-with-google-oauth-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-oauth-client-secret"
# Optional outside local development if OAuth callbacks need an absolute deployed URL.
# AUTH_URL="https://your-app.example.com"
# NEXTAUTH_URL="https://your-app.example.com"
# Google OAuth callback URL for local development:
# http://localhost:3000/api/auth/callback/google
# Local S3-compatible object storage.
# MinIO is the default local target today; AWS S3 can use the same helper later
# by changing env values and typically omitting S3_ENDPOINT.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="ulazytools"
S3_SECRET_ACCESS_KEY="ulazytools-minio-secret"
S3_BUCKET="ulazy-pdf-dev"
# MinIO/local S3-compatible backends usually need path-style URLs enabled.
S3_FORCE_PATH_STYLE="true"
