{
  "name": "ulazytools-online",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "ci:smoke": "node scripts/ci-runtime-smoke.mjs",
    "test": "jest --runInBand",
    "worker:dev": "dotenv -e .env.local -- tsx watch src/workers/pdfWorker.ts",
    "verify": "npm run typecheck && npm run lint && npm run build",
    "typecheck": "tsc --noEmit --incremental false --project tsconfig.typecheck.json",
    "prisma:generate": "dotenv -e .env.local -- prisma generate",
    "prisma:validate": "dotenv -e .env.local -- prisma validate",
    "prisma:studio": "dotenv -e .env.local -- prisma studio",
    "storage:verify": "dotenv -e .env.local -- tsx scripts/verify-storage.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@prisma/client": "^6.16.3",
    "bullmq": "^5.71.1",
    "ioredis": "^5.10.1",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.30",
    "pino": "^9.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.6",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.8.1",
    "prisma": "^6.16.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
